# ============================================================
# nailX バックエンド 環境変数テンプレート
# このファイルをコピーして backend/.env を作成してください。
#
# ⚠️  コンテナ内で使用するため DATABASE_URL / REDIS_URL は
#     Docker Compose のサービス名（postgres / redis）を使います。
#     コンテナ外（ホスト直接実行）の場合は localhost に変更してください。
# ============================================================

# Database
DATABASE_URL=postgres://nailx:nailx_dev@postgres:5432/nailx?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379/0

# Firebase Admin SDK（サービスアカウント JSON ファイルのパス）
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# AWS
AWS_DEFAULT_REGION=ap-northeast-1
S3_BUCKET=nailx-media-dev
CDN_BASE_URL=http://localhost:8080

# SQS（開発時は空欄でも可。空欄の場合 Worker は自動スキップ）
SQS_SIMILARITY_QUEUE_URL=

# Stripe（テスト環境は sk_test_ から始まるキーを使用）
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Server
PORT=8080
